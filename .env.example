# Skopiuj ten plik jako .env.local i uzupełnij wartości przed wdrożeniem na Vercel.
# W Vercel Dashboard ustaw te zmienne w: Settings → Environment Variables

# Konfiguracja serwera SMTP (np. Gmail, Outlook, SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=twoj@email.com
SMTP_PASS=twoje-haslo-lub-token-aplikacji

# Adres nadawcy widoczny w emailach
SMTP_FROM=twoj@email.com

# Adres email właścicielki (na który trafiają powiadomienia o rezerwacjach)
OWNER_EMAIL=kasia@littleyogini.com
